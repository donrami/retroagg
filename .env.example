# RetroAgg Environment Variables Template
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=RetroAgg
DEBUG=False

# Database (use a cloud database like Supabase, Neon, or PlanetScale for production)
DATABASE_URL=sqlite+aiosqlite:///data/retroagg.db

# RSS Fetching Settings
FETCH_INTERVAL_MINUTES=15
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# UI Settings
MAX_SUMMARY_LENGTH=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
