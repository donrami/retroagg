{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ],
    "env": {
        "PYTHON_VERSION": "3.11"
    }
}
